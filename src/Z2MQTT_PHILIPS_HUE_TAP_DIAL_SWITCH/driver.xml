        <name>Connection Quality</name>
        <type>STRING</type>
        <default>Unknown</default>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Log Level</name>
        <type>LIST</type>
        <readonly>false</readonly>
        <default>Warn</default>
        <items>
          <item>Off</item>
          <item>Fatal</item>
          <item>Error</item>
          <item>Warn</item>
          <item>Info</item>
          <item>Debug</item>
          <item>Trace</item>
        </items>
      </property>
      <property>
        <name>Log Mode</name>
        <type>LIST</type>
        <readonly>false</readonly>
        <default>Off</default>
        <items>
          <item>Off</item>
          <item>Print</item>
          <item>Log</item>
          <item>Print and Log</item>
        </items>
      </property>
    </properties>
